<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Beam Report &mdash; {{ now }}</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.css">
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/katex.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.21/dist/contrib/auto-render.min.js"
  onload="renderMathInElement(document.body, {delimiters:[{left:'$$',right:'$$',display:true},{left:'$',right:'$',display:false}]});">
</script>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
<style>
  :root {
    --bg: #fafafa; --card: #fff; --border: #e5e7eb;
    --text: #1f2937; --muted: #6b7280;
    --accent: #6366f1; --green: #16a34a; --red: #dc2626;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: Inter, "Segoe UI", "Helvetica Neue", sans-serif;
    background: var(--bg); color: var(--text);
    line-height: 1.5; padding: 2rem;
    max-width: 1100px; margin: 0 auto;
  }
  h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: .25rem; }
  h2 {
    font-size: 1.25rem; font-weight: 600;
    margin: 2.5rem 0 1rem;
    border-bottom: 2px solid var(--border); padding-bottom: .5rem;
  }
  h3 {
    font-size: 1.05rem; font-weight: 600;
    margin: 1.5rem 0 .75rem; color: var(--text);
  }
  .subtitle { color: var(--muted); font-size: .9rem; margin-bottom: 1.5rem; }
  .grid { display: grid; gap: 1rem; }
  .grid-2 { grid-template-columns: 1fr 1fr; }
  .grid-4 { grid-template-columns: repeat(4, 1fr); }
  @media (max-width: 768px) { .grid-2, .grid-4 { grid-template-columns: 1fr 1fr; } }
  .card {
    background: var(--card); border: 1px solid var(--border);
    border-radius: .75rem; padding: 1.25rem;
  }

  /* KPI */
  .kpi { text-align: center; }
  .kpi .value { font-size: 1.6rem; font-weight: 700; }
  .kpi .label { font-size: .75rem; color: var(--muted); margin-top: .15rem; }
  .kpi .sub {
    font-size: .7rem; margin-top: .3rem; padding: 2px 8px;
    border-radius: 99px; display: inline-block; font-weight: 600;
  }
  .kpi .sub.ok   { background: #dcfce7; color: var(--green); }
  .kpi .sub.fail { background: #fee2e2; color: var(--red); }
  .kpi .sub.neutral { background: #f3f4f6; color: var(--muted); }

  /* Table */
  table { width: 100%; border-collapse: collapse; font-size: .85rem; }
  th {
    text-align: left; font-weight: 600; padding: .6rem .75rem;
    border-bottom: 2px solid var(--border); white-space: nowrap;
  }
  td { padding: .5rem .75rem; border-bottom: 1px solid var(--border); }
  .right { text-align: right; }

  /* Ratio badge */
  .ratio {
    cursor: pointer; font-weight: 600; border-radius: .35rem;
    padding: .2rem .5rem; display: inline-block; min-width: 4rem;
    text-align: center; transition: opacity .15s;
  }
  .ratio:hover { opacity: .75; }
  .ratio.ok   { background: #dcfce7; color: var(--green); }
  .ratio.fail { background: #fee2e2; color: var(--red); }

  /* Dialog */
  dialog {
    border: 1px solid var(--border); border-radius: .75rem; padding: 0;
    max-width: 640px; width: 90vw;
    margin: auto;
    box-shadow: 0 8px 32px rgba(0,0,0,.12);
  }
  dialog::backdrop { background: rgba(0,0,0,.3); }
  dialog .dlg-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1rem 1.25rem; border-bottom: 1px solid var(--border);
  }
  dialog .dlg-header h3 { font-size: 1rem; font-weight: 600; margin: 0; }
  dialog .dlg-close {
    background: none; border: none; font-size: 1.25rem;
    cursor: pointer; color: var(--muted); padding: .25rem;
  }
  dialog .dlg-close:hover { color: var(--text); }
  dialog .dlg-body { padding: 1.25rem; }
  dialog pre {
    background: #f9fafb; border: 1px solid var(--border);
    border-radius: .5rem; padding: 1rem; font-size: .8rem;
    overflow-x: auto; white-space: pre-wrap; margin: 0;
  }

  /* Deflection value */
  .defl-val { font-size: .8rem; color: var(--muted); margin-top: .15rem; }

  .chart-card { border-radius: .75rem; overflow: hidden; }

  /* Tabs */
  .tabs-wrapper { margin-top: 2.5rem; }
  .tabs-wrapper h2 { margin-top: 0; }
  .tabs {
    display: flex; gap: 0; position: relative; z-index: 1;
    border-bottom: 1px solid var(--border);
  }
  .tab-btn {
    padding: .6rem 1.25rem; font-size: .85rem; font-weight: 600;
    border: none; border-bottom: 2px solid transparent;
    background: none; color: var(--muted);
    cursor: pointer; transition: color .15s, border-color .15s;
  }
  .tab-btn:hover { color: var(--text); }
  .tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  footer {
    margin-top: 3rem; text-align: center; font-size: .75rem;
    color: var(--muted); border-top: 1px solid var(--border); padding-top: 1rem;
  }
</style>
</head>
<body>

<h1>Beam Analysis Report</h1>
<p class="subtitle">
  Generated {{ now }} &middot;
  L = {{ length }} m &middot;
  {{ b | int }}&times;{{ h | int }} mm &middot;
  {{ grade }}
</p>

{# ══════════════════════════════════════════════════════════ #}
{# ── SECTION 1: CASE DEFINITION ────────────────────────── #}
{# ══════════════════════════════════════════════════════════ #}
<h2>Case Definition</h2>
<div class="grid grid-2">
  {# ── Beam definition ── #}
  <div class="card">
    <table>
      <tr><th colspan="2">Beam</th></tr>
      <tr><td>Span</td><td class="right">{{ length }} m</td></tr>
      <tr><td>Left support</td><td class="right">{{ support_left }}</td></tr>
      <tr><td>Right support</td><td class="right">{{ support_right }}</td></tr>
    </table>
    {# SVG beam schema #}
    <svg viewBox="0 0 400 100" style="width:100%;height:auto;margin-top:.75rem;" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="hatch" patternUnits="userSpaceOnUse" width="6" height="6" patternTransform="rotate(45)">
          <line x1="0" y1="0" x2="0" y2="6" stroke="#6b7280" stroke-width="1"/>
        </pattern>
      </defs>
      {# Beam line #}
      <line x1="60" y1="45" x2="340" y2="45" stroke="#1f2937" stroke-width="3" stroke-linecap="round"/>
      {# Span dimension #}
      <line x1="60" y1="28" x2="340" y2="28" stroke="#6b7280" stroke-width="0.8"/>
      <line x1="60" y1="24" x2="60" y2="32" stroke="#6b7280" stroke-width="0.8"/>
      <line x1="340" y1="24" x2="340" y2="32" stroke="#6b7280" stroke-width="0.8"/>
      <text x="200" y="24" text-anchor="middle" font-size="11" fill="#6b7280" font-family="Inter, sans-serif">L = {{ length }} m</text>
      {# Left support #}
      {% if support_left == 'fixed' %}
      <rect x="42" y="30" width="18" height="36" fill="url(#hatch)" stroke="#1f2937" stroke-width="1.5"/>
      {% elif support_left == 'pinned' %}
      <polygon points="60,48 48,72 72,72" fill="none" stroke="#1f2937" stroke-width="1.5" stroke-linejoin="round"/>
      <line x1="44" y1="76" x2="76" y2="76" stroke="#1f2937" stroke-width="1.5"/>
      {% elif support_left == 'roller_x' or support_left == 'roller_y' %}
      <polygon points="60,48 48,68 72,68" fill="none" stroke="#1f2937" stroke-width="1.5" stroke-linejoin="round"/>
      <circle cx="54" cy="74" r="4" fill="none" stroke="#1f2937" stroke-width="1.5"/>
      <circle cx="66" cy="74" r="4" fill="none" stroke="#1f2937" stroke-width="1.5"/>
      <line x1="44" y1="80" x2="76" y2="80" stroke="#1f2937" stroke-width="1.5"/>
      {% endif %}
      {# Right support #}
      {% if support_right == 'fixed' %}
      <rect x="340" y="30" width="18" height="36" fill="url(#hatch)" stroke="#1f2937" stroke-width="1.5"/>
      {% elif support_right == 'pinned' %}
      <polygon points="340,48 328,72 352,72" fill="none" stroke="#1f2937" stroke-width="1.5" stroke-linejoin="round"/>
      <line x1="324" y1="76" x2="356" y2="76" stroke="#1f2937" stroke-width="1.5"/>
      {% elif support_right == 'roller_x' or support_right == 'roller_y' %}
      <polygon points="340,48 328,68 352,68" fill="none" stroke="#1f2937" stroke-width="1.5" stroke-linejoin="round"/>
      <circle cx="334" cy="74" r="4" fill="none" stroke="#1f2937" stroke-width="1.5"/>
      <circle cx="346" cy="74" r="4" fill="none" stroke="#1f2937" stroke-width="1.5"/>
      <line x1="324" y1="80" x2="356" y2="80" stroke="#1f2937" stroke-width="1.5"/>
      {% endif %}
    </svg>
  </div>

  {# ── Loads ── #}
  <div class="card">
    <table>
      <tr><th>Case</th><th>Type</th><th>Magnitude</th><th>Position</th></tr>
      {% for ld in loads %}
      <tr>
        <td>${{ ld.case }}$</td>
        <td>{{ ld.type }}</td>
        <td>{{ ld.magnitude }}</td>
        <td>{{ ld.position }}</td>
      </tr>
      {% endfor %}
    </table>
  </div>

  {# ── Cross section ── #}
  <div class="card">
    <table>
      <tr><th colspan="2">Cross Section</th></tr>
      <tr><td>Width (b)</td><td class="right">{{ b | int }} mm</td></tr>
      <tr><td>Height (h)</td><td class="right">{{ h | int }} mm</td></tr>
      <tr><td>Area</td><td class="right">{{ "%.1f" | format(A_cm2) }} cm²</td></tr>
      <tr><td>I<sub>z</sub></td><td class="right">{{ "%.1f" | format(Iz_cm4) }} cm⁴</td></tr>
      <tr><td>I<sub>y</sub></td><td class="right">{{ "%.1f" | format(Iy_cm4) }} cm⁴</td></tr>
      <tr><td>W<sub>el,z</sub></td><td class="right">{{ "%.1f" | format(Wel_z_cm3) }} cm³</td></tr>
    </table>
  </div>

  {# ── Material ── #}
  <div class="card">
    <table>
      <tr><th colspan="2">Material (EC5)</th></tr>
      <tr><td>Grade</td><td class="right">{{ grade }}</td></tr>
      <tr><td>Service class</td><td class="right">{{ service_class }}</td></tr>
      <tr><td>$\gamma_M$</td><td class="right">{{ "%.2f" | format(gamma_M) }}</td></tr>
      <tr><td>$k_{mod}$ (G: {{ load_duration_G }})</td><td class="right">{{ "%.2f" | format(kmod_G) }}</td></tr>
      <tr><td>$k_{mod}$ (Q: {{ load_duration_Q }})</td><td class="right">{{ "%.2f" | format(kmod_Q) }}</td></tr>
      <tr><td>$f_{m,k}$</td><td class="right">{{ "%.1f" | format(fmk) }} MPa</td></tr>
      <tr><td>$f_{v,k}$</td><td class="right">{{ "%.1f" | format(fvk) }} MPa</td></tr>
      <tr><td>$f_{m,d}$ (Q)</td><td class="right">{{ "%.2f" | format(fmd_Q) }} MPa</td></tr>
      <tr><td>$f_{v,d}$ (Q)</td><td class="right">{{ "%.2f" | format(fvd_Q) }} MPa</td></tr>
      <tr><td>$E_{0,mean}$</td><td class="right">{{ "%.0f" | format(E0mean) }} MPa</td></tr>
    </table>
  </div>
</div>

{# ══════════════════════════════════════════════════════════ #}
{# ── SECTION 2: RESULTS ───────────────────────────────── #}
{# ══════════════════════════════════════════════════════════ #}
<h2>Results</h2>
<div class="grid grid-4">
  <div class="card kpi">
    <div class="value">{{ "%.2f" | format(m_max) }}</div>
    <div class="label">M<sub>max</sub> (kN&middot;m)</div>
    <div class="sub neutral">{{ m_combo }}</div>
  </div>
  <div class="card kpi">
    <div class="value">{{ "%.2f" | format(v_max) }}</div>
    <div class="label">V<sub>max</sub> (kN)</div>
    <div class="sub neutral">{{ v_combo }}</div>
  </div>
  <div class="card kpi">
    <div class="value">{{ "%.2f" | format(d_max) }}</div>
    <div class="label">&delta;<sub>max</sub> (mm)</div>
    <div class="sub neutral">{{ d_combo }}</div>
  </div>
  <div class="card kpi">
    <div class="value">{{ "%.3f" | format(worst_ratio) }}</div>
    <div class="label">Worst Ratio</div>
    <div class="sub {{ 'ok' if all_ok else 'fail' }}">{{ 'ALL PASS' if all_ok else 'FAIL' }}</div>
  </div>
</div>

{# ── EC5 Verification ─────────────────────────────────── #}
<h3>EC5 Verification</h3>
<div class="grid grid-2">
  {# ELU table #}
  <div class="card" style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th>ULS</th>
          <th>Combination</th>
          <th class="right">Bending</th>
          <th class="right">Shear</th>
        </tr>
      </thead>
      <tbody>
        {% for c in elu_combos %}
        {% set ci = loop.index0 %}
        <tr>
          <td>{{ c.label }}</td>
          <td>${{ c.latex }}$</td>
          {% for key in ['bending', 'shear'] %}
            {% set chk = c[key] %}
            {% if chk %}
            <td class="right">
              <span class="ratio {{ 'ok' if chk.is_ok else 'fail' }}"
                    onclick="document.getElementById('dlg-elu-{{ ci }}-{{ key[0] }}').showModal()">
                {{ "%.1f" | format(chk.ratio_pct) }}%
              </span>
            </td>
            {% else %}
            <td class="right">&mdash;</td>
            {% endif %}
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {# ELS table #}
  <div class="card" style="overflow-x:auto">
    <table>
      <thead>
        <tr>
          <th>SLS</th>
          <th>Combination</th>
          <th class="right">Deflection</th>
          <th class="right">Max (mm)</th>
        </tr>
      </thead>
      <tbody>
        {% for c in els_combos %}
        {% set chk = c.deflection %}
        <tr>
          <td>{{ c.label }}</td>
          <td>${{ c.latex }}$</td>
          <td class="right">
            <span class="ratio {{ 'ok' if chk.is_ok else 'fail' }}"
                  onclick="document.getElementById('dlg-els-{{ loop.index0 }}-d').showModal()">
              {{ "%.1f" | format(chk.ratio_pct) }}%
            </span>
          </td>
          <td class="right">
            <span class="defl-val">{{ "%.2f" | format(chk.defl_mm) }} / {{ "%.2f" | format(chk.limit_mm) }}</span>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>

{# ── DIALOGS ─────────────────────────────────────────────── #}
{% for c in elu_combos %}
  {% set ci = loop.index0 %}
  {% for key, label in [('bending', 'Bending'), ('shear', 'Shear')] %}
    {% set chk = c[key] %}
    {% if chk %}
    <dialog id="dlg-elu-{{ ci }}-{{ key[0] }}">
      <div class="dlg-header">
        <h3>{{ label }} &mdash; ${{ c.latex }}$ &mdash; {{ 'OK' if chk.is_ok else 'FAIL' }} ({{ "%.1f" | format(chk.ratio_pct) }}%)</h3>
        <button class="dlg-close" onclick="this.closest('dialog').close()">&times;</button>
      </div>
      <div class="dlg-body"><pre>{{ chk.details }}</pre></div>
    </dialog>
    {% endif %}
  {% endfor %}
{% endfor %}
{% for c in els_combos %}
  {% set chk = c.deflection %}
  <dialog id="dlg-els-{{ loop.index0 }}-d">
    <div class="dlg-header">
      <h3>Deflection &mdash; ${{ c.latex }}$ &mdash; {{ 'OK' if chk.is_ok else 'FAIL' }} ({{ "%.1f" | format(chk.ratio_pct) }}%)</h3>
      <button class="dlg-close" onclick="this.closest('dialog').close()">&times;</button>
    </div>
    <div class="dlg-body"><pre>{{ chk.details }}</pre></div>
  </dialog>
{% endfor %}

{# ── Diagrams (tabbed) ──────────────────────────────────── #}
<div class="tabs-wrapper">
<h3>Diagrams</h3>
<div class="tabs">
  <button class="tab-btn active" data-tab="tab-forces">Internal Forces</button>
  <button class="tab-btn" data-tab="tab-envelope">Envelopes</button>
  <button class="tab-btn" data-tab="tab-deflection">Deflection</button>
</div>
<div class="card chart-card" style="border-radius: 0 0 .75rem .75rem; border-top: none;">
  <div id="tab-forces" class="tab-panel active">
    <div id="chart-forces" style="width:100%;height:700px;"></div>
  </div>
  <div id="tab-envelope" class="tab-panel">
    <div id="chart-envelope" style="width:100%;height:700px;"></div>
  </div>
  <div id="tab-deflection" class="tab-panel">
    <div id="chart-deflection" style="width:100%;height:400px;"></div>
  </div>
</div>
</div>

<footer>Beambo &mdash; 2D Beam Analysis &middot; PyNite + Eurocode 5</footer>

<script>
// Dialog close-on-backdrop
document.querySelectorAll('dialog').forEach(d => {
  d.addEventListener('click', e => { if (e.target === d) d.close(); });
  d.addEventListener('open', () => {
    if (typeof renderMathInElement !== 'undefined') renderMathInElement(d);
  });
});

// ── Tabs ──
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    const panel = document.getElementById(btn.dataset.tab);
    panel.classList.add('active');
    // Plotly needs a resize when the container becomes visible
    const chart = panel.querySelector('[id^="chart-"]');
    if (chart) Plotly.Plots.resize(chart);
  });
});

// ── Chart data ──
const D = {{ chart_data_json }};
const x = D.x;

const COLORS = [
  '#6366f1', '#f59e0b', '#10b981', '#ef4444', '#8b5cf6',
  '#06b6d4', '#ec4899', '#14b8a6', '#f97316', '#3b82f6',
];

const layoutBase = {
  font: { family: 'Inter, Segoe UI, Helvetica Neue, sans-serif', size: 12 },
  paper_bgcolor: 'transparent',
  plot_bgcolor: '#fff',
  margin: { l: 60, r: 20, t: 40, b: 30 },
  hovermode: 'x unified',
  legend: { orientation: 'h', y: -0.05, x: 0.5, xanchor: 'center', font: { size: 10 } },
  xaxis: { gridcolor: '#e5e7eb', zeroline: true, zerolinecolor: '#999' },
  yaxis: { gridcolor: '#e5e7eb', zeroline: true, zerolinecolor: '#999' },
};
const plotCfg = { responsive: true, displaylogo: false };

// ── Tab 1: Internal Forces (N, V, M) ──
(function() {
  const traces = [];
  const comboNames = Object.keys(D.elu);

  // N traces
  comboNames.forEach((name, i) => {
    const s = D.elu[name];
    if (!s.N || s.N.length === 0) return;
    traces.push({
      x: x, y: s.N, name: name, type: 'scatter', mode: 'lines',
      line: { color: COLORS[i % COLORS.length], width: 1.5 },
      xaxis: 'x', yaxis: 'y',
      legendgroup: name, showlegend: true,
    });
  });
  if (D.envelopes.N_max.length) {
    traces.push({
      x: x, y: D.envelopes.N_max, name: 'Envelope', type: 'scatter', mode: 'lines',
      line: { color: 'steelblue', width: 0 }, fill: 'none',
      xaxis: 'x', yaxis: 'y', showlegend: false,
    });
    traces.push({
      x: x, y: D.envelopes.N_min, type: 'scatter', mode: 'lines',
      line: { color: 'steelblue', width: 0 }, fill: 'tonexty',
      fillcolor: 'rgba(70,130,180,0.12)',
      xaxis: 'x', yaxis: 'y', showlegend: false,
    });
  }

  // V traces
  comboNames.forEach((name, i) => {
    const s = D.elu[name];
    if (!s.V || s.V.length === 0) return;
    traces.push({
      x: x, y: s.V, name: name, type: 'scatter', mode: 'lines',
      line: { color: COLORS[i % COLORS.length], width: 1.5 },
      xaxis: 'x2', yaxis: 'y2',
      legendgroup: name, showlegend: false,
    });
  });
  if (D.envelopes.V_max.length) {
    traces.push({
      x: x, y: D.envelopes.V_max, type: 'scatter', mode: 'lines',
      line: { width: 0 }, fill: 'none',
      xaxis: 'x2', yaxis: 'y2', showlegend: false,
    });
    traces.push({
      x: x, y: D.envelopes.V_min, type: 'scatter', mode: 'lines',
      line: { width: 0 }, fill: 'tonexty',
      fillcolor: 'rgba(220,60,60,0.12)',
      xaxis: 'x2', yaxis: 'y2', showlegend: false,
    });
  }

  // M traces (inverted y)
  comboNames.forEach((name, i) => {
    const s = D.elu[name];
    if (!s.M || s.M.length === 0) return;
    traces.push({
      x: x, y: s.M, name: name, type: 'scatter', mode: 'lines',
      line: { color: COLORS[i % COLORS.length], width: 1.5 },
      xaxis: 'x3', yaxis: 'y3',
      legendgroup: name, showlegend: false,
    });
  });
  if (D.envelopes.M_max.length) {
    traces.push({
      x: x, y: D.envelopes.M_max, type: 'scatter', mode: 'lines',
      line: { width: 0 }, fill: 'none',
      xaxis: 'x3', yaxis: 'y3', showlegend: false,
    });
    traces.push({
      x: x, y: D.envelopes.M_min, type: 'scatter', mode: 'lines',
      line: { width: 0 }, fill: 'tonexty',
      fillcolor: 'rgba(40,160,80,0.12)',
      xaxis: 'x3', yaxis: 'y3', showlegend: false,
    });
  }

  Plotly.newPlot('chart-forces', traces, {
    ...layoutBase,
    title: { text: D.title, font: { size: 14, weight: 'bold' } },
    grid: { rows: 3, columns: 1, subplots: [['xy'],['x2y2'],['x3y3']], roworder: 'top to bottom' },
    xaxis:  { ...layoutBase.xaxis, matches: 'x3', showticklabels: false },
    xaxis2: { ...layoutBase.xaxis, matches: 'x3', showticklabels: false },
    xaxis3: { ...layoutBase.xaxis, title: 'Position along beam (m)' },
    yaxis:  { ...layoutBase.yaxis, title: 'N (kN)' },
    yaxis2: { ...layoutBase.yaxis, title: 'V (kN)' },
    yaxis3: { ...layoutBase.yaxis, title: 'M (kN·m)', autorange: 'reversed' },
    legend: { ...layoutBase.legend, y: -0.02 },
    margin: { l: 60, r: 20, t: 50, b: 50 },
  }, plotCfg);
})();

// ── Tab 2: ELU Envelopes ──
(function() {
  const traces = [];
  const configs = [
    { key: 'N', color: 'rgb(70,130,180)', yaxis: 'y', xaxis: 'x' },
    { key: 'V', color: 'rgb(205,92,92)', yaxis: 'y2', xaxis: 'x2' },
    { key: 'M', color: 'rgb(46,139,87)', yaxis: 'y3', xaxis: 'x3' },
  ];

  configs.forEach(c => {
    const maxArr = D.envelopes[c.key + '_max'];
    const minArr = D.envelopes[c.key + '_min'];
    if (!maxArr.length) return;
    const fill = c.color.replace('rgb', 'rgba').replace(')', ',0.15)');
    traces.push({
      x: x, y: maxArr, name: c.key + ' Max', type: 'scatter', mode: 'lines',
      line: { color: c.color, width: 1.5 },
      xaxis: c.xaxis, yaxis: c.yaxis,
    });
    traces.push({
      x: x, y: minArr, name: c.key + ' Min', type: 'scatter', mode: 'lines',
      line: { color: c.color, width: 1.5, dash: 'dash' },
      fill: 'tonexty', fillcolor: fill,
      xaxis: c.xaxis, yaxis: c.yaxis,
    });
  });

  Plotly.newPlot('chart-envelope', traces, {
    ...layoutBase,
    title: { text: 'ELU Envelope', font: { size: 14, weight: 'bold' } },
    grid: { rows: 3, columns: 1, subplots: [['xy'],['x2y2'],['x3y3']], roworder: 'top to bottom' },
    xaxis:  { ...layoutBase.xaxis, matches: 'x3', showticklabels: false },
    xaxis2: { ...layoutBase.xaxis, matches: 'x3', showticklabels: false },
    xaxis3: { ...layoutBase.xaxis, title: 'Position along beam (m)' },
    yaxis:  { ...layoutBase.yaxis, title: 'N (kN)' },
    yaxis2: { ...layoutBase.yaxis, title: 'V (kN)' },
    yaxis3: { ...layoutBase.yaxis, title: 'M (kN·m)', autorange: 'reversed' },
    margin: { l: 60, r: 20, t: 50, b: 50 },
  }, plotCfg);
})();

// ── Tab 3: Deflection (ELS) ──
(function() {
  const traces = [];
  const elsNames = Object.keys(D.els);

  elsNames.forEach((name, i) => {
    traces.push({
      x: x, y: D.els[name].delta_mm, name: name, type: 'scatter', mode: 'lines',
      line: { color: COLORS[i % COLORS.length], width: 1.5 },
    });
  });
  // Limit line
  traces.push({
    x: [x[0], x[x.length-1]], y: [-D.deflection_limit_mm, -D.deflection_limit_mm],
    name: D.deflection_limit_label, type: 'scatter', mode: 'lines',
    line: { color: '#dc2626', width: 1.5, dash: 'dash' },
  });

  Plotly.newPlot('chart-deflection', traces, {
    ...layoutBase,
    title: { text: 'Deflection (ELS)', font: { size: 14, weight: 'bold' } },
    xaxis: { ...layoutBase.xaxis, title: 'Position along beam (m)' },
    yaxis: { ...layoutBase.yaxis, title: 'δ (mm)' },
    margin: { l: 60, r: 20, t: 50, b: 50 },
  }, plotCfg);
})();
</script>

</body>
</html>
